   public class  OpportunityProcessing implements Queueable {
    Set<Id> oppIds;//taking the oppid which we have taken from 

    
   
    public void execute(QueueableContext) {
        List<Opportunity> opps = [SELECT Id, Amount, Description FROM Opportunity WHERE Id IN :oppIds];
        for (Opportunity opp : opps) {
            if(opp.Amount > 50000){
                opp.Description = 'High Value Deal';

            }else{
                  opp.Description =  'Standard Deal';
            }
            
        update opps;

       
        Database.executeBatch(new taskProcessing (oppIds), 200);//making the instance of the batch class and passing the oppid
    }
}
